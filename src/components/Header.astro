---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";

// Определяем текущий путь
const currentPath = Astro.url.pathname;
// Проверяем, находимся ли мы на английской версии
const isEnglish = currentPath.startsWith("/en/") || currentPath === "/en";

// Функция для получения пути на нужном языке
const getLocalizedPath = (targetLang: "ru" | "en"): string => {
  // Получаем текущий путь без префикса /en
  let pathWithoutLang = currentPath;
  if (currentPath === "/en") {
    pathWithoutLang = "/";
  } else if (currentPath.startsWith("/en/")) {
    pathWithoutLang = currentPath.replace("/en", "");
  }

  // Обрабатываем корневой путь
  if (pathWithoutLang === "") {
    pathWithoutLang = "/";
  }

  if (targetLang === "ru") {
    return pathWithoutLang;
  } else {
    // Для английской версии
    if (pathWithoutLang === "/") {
      return "/en";
    }
    return `/en${pathWithoutLang}`;
  }
};

// Функция для проверки активной ссылки в навигации
const isNavActive = (path: string): boolean => {
  if (isEnglish) {
    return (
      currentPath === `/en${path}` || (path === "/" && currentPath === "/en")
    );
  }
  return currentPath === path;
};
---

<header>
  <nav>
    <h2><a href={isEnglish ? "/en" : "/"}>{SITE_TITLE}</a></h2>
    <div class="internal-links">
      <HeaderLink href={isEnglish ? "/en/about" : "/about"}>
        {isEnglish ? "About me" : "Обо мне"}
      </HeaderLink>
      <HeaderLink href={isEnglish ? "/en/blog" : "/blog"}>
        {isEnglish ? "Blog" : "Блог"}
      </HeaderLink>
    </div>

    <!-- Переключатель языка -->
    <div class="language-switcher">
      <a
        href={getLocalizedPath("ru")}
        class={`lang-link ${!isEnglish ? "active" : ""}`}>RU</a
      >
      <a
        href={getLocalizedPath("en")}
        class={`lang-link ${isEnglish ? "active" : ""}`}>EN</a
      >
    </div>

    <div class="social-links">
      <a href="https://t.me/Okotw" target="_blank">
        <span class="sr-only">Find me in Telegram</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
          <path
            fill="currentColor"
            d="M13.5 2.5L1.5 6.5L5.5 9L12 4L7 10L10.5 13.5L13.5 2.5Z"></path>
        </svg>
      </a>
      <a href="https://github.com/nasty23-star" target="_blank">
        <span class="sr-only">Go to my GitHub repo</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
          <path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
      </a>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 1em;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
  }
  h2 {
    margin: 0;
    font-size: 1em;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  nav a {
    padding: 1em 0.5em;
    color: var(--black);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
  .social-links,
  .social-links a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Стили для переключателя языка */
  .language-switcher {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-right: 1rem;
    font-family: monospace;
    font-weight: bold;
  }

  .lang-link {
    color: #60a5fa;
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: all 0.2s;
    font-size: 0.9rem;
  }

  .lang-link:hover {
    color: #93c5fd;
    background: rgba(59, 130, 246, 0.2);
  }

  .lang-link.active {
    color: #ffffff;
    /* background: #3b82f6; */
    text-shadow: none;
  }

  .lang-separator {
    color: #3b82f6;
    opacity: 0.5;
  }

  @media (max-width: 720px) {
    .social-links {
      gap: 0.25rem;
    }
    .language-switcher {
      margin-right: 0.5rem;
    }
  }
</style>
